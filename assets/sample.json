{{- with .Rotate "language" -}}
  {{/* Rotate to get FR version of example website */}}
  {{- range . -}}
    {{- if eq .Site.Language.Name "fr" -}}
      {{- template "json" . -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- define "json" -}}
  {{- $paths := slice "/fr/blocks/blocs-de-mise-en-page/" -}}
  {{- range .Site.Sections -}}
    {{- if and (ne .Type "sitemap") -}}
      {{- $paths = $paths | append .Params.url -}}
      {{- range $index, $page := (where .Site.Pages "Section" .Type) -}}
        {{- if eq $index 5 -}}
          {{- with $page.Params.url -}}
            {{- $paths = $paths | append . -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
  {{- $paths | uniq | jsonify -}}
{{- end -}}
